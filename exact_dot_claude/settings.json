{
  "permissions": {
    "allow": [
      "mcp__atlassian__*",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "Bash(dstan:*)",
      "Bash(d php artisan test --filter=CronJob)",
      "Bash(composer show:*)",
      "Bash(cat:*)",
      "Bash(python3:*)",
      "Bash(grep:*)",
      "Bash(sail test)",
      "Bash(./vendor/bin/sail test:*)",
      "Bash(d:*)",
      "Bash(da tinker --execute=\"App\\Actions\\Backup\\CreateBackupAction::run(''aliquam_myapp'', App\\Enums\\BackupType::Monthly);\")",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(diff:*)",
      "Bash(tree:*)",
      "Bash(which:*)",
      "Bash(file:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(jq:*)",
      "Bash(du:*)",
      "Bash(realpath:*)",
      "Bash(da tinker:*)",
      "Bash(docker ps:*)",
      "Bash(bash -c './vendor/bin/sail test --filter=DatabaseBackupTest')",
      "Bash(./vendor/bin/sail exec -u panel laravel.test php -r:*)",
      "Bash(./vendor/bin/sail exec redis redis-cli:*)",
      "Bash(./vendor/bin/sail exec:*)",
      "Bash(ls:*)",
      "Bash(done)",
      "Bash(git log:*)",
      "WebFetch(domain:filamentphp.com)",
      "Skill(hookify:writing-rules)",
      "Bash(:)",
      "Bash(php artisan dev:reset:*)",
      "Bash(wc:*)",
      "Bash(./vendor/bin/sail up:*)",
      "Bash(php -l:*)",
      "Bash(da queue:failed:*)",
      "Bash(da queue:flush:*)",
      "Bash(server {)",
      "Bash(listen:*)",
      "Bash(__NEW_LINE__ listen 443 ssl)",
      "Bash(__NEW_LINE__ http2 on)",
      "Bash(__NEW_LINE__ server_name ssl-pending-test.local)",
      "Bash(__NEW_LINE__ ssl_reject_handshake on)",
      "Bash(__NEW_LINE__ })",
      "Bash(EOF)",
      "Bash(__NEW_LINE__ d nginx -t)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/allow-handoff-write.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/inject-handoff.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "hookify@claude-code-plugins": true,
    "php-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "autoUpdatesChannel": "stable"
}
